entero cargar_sub(real a[N], real b[N])
comienzo
entero i, j
j = 0
Para i desde 0 hasta N - 1
	Si(a[i] > 1000000)
	entonces
		b[j] = a[i]
		j = j + 1
	finSi
finPara
retorna(j)
fin

void mostrar(real a[N], entero j)
