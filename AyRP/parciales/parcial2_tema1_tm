algoritmo consultorio médico

constante entero N = 30

registro paciente {
	cadena nombre
	entero edad
	entero dni
}

void cargar(paciente a[N])
comienzo 
entero i, edad, dni
cadena nombre
Para i desde 0 hasta N - 1
	Escribir "Ingrese nombre del paciente:"
	Leer nombre
	a[i].nombre = nombre
	Escribir "Ingrese edad del paciente"
	Leer edad
	a[i].edad = edad
	Escribir "Ingrese DNI del paciente"
	Leer dni
	a[i].dni = dni
finPara
retorna()
fin

void ordenar_asc(paciente a[N])
comienzo
entero i, j
paciente aux
Para i desde 0 hasta N - 1
	j = i - 1
	aux = a[i]
	Mientras(j >= 0 && aux > a[j])
		a[j + 1] = a[j]
		j = j + 1
	finMientras
	a[j + 1] = aux
finPara
retorna()
fin

entero busqueda_bin(paciente a[N], cadena nombre)
comienzo
entero dni, inf, sup, medio
booleano encontrado
encontrado = falso
inf = 0
sup = N - 1
medio = (inf + sup) div 2
Mientras ((econtrado == falso) Y (inf <= sup))
	Si(a[medio].nombre == nombre)
	entonces
		encontrado = verdadero
	sino 
		Si(nombre < a[medio].nombre)
		entonces
			sup = medio - 1
		sino inf = medio + 1
		finSi
	finSi
	medio = (inf + sup) div 2
finMientras
Si(encontrado == verdadero)
entonces
	retorna(medio)
sino retorna(-1)
finSi
fin

entero prom(paciente a[N])
comienzo
entero p, acum, i
acum = 0
Para i desde 0 hasta N - 1
	acum = acum + a[i].edad
finPara
p = acum div N
retorna(p)
fin

/* algoritmo principal */
comienzo
entero i
paciente pacientes[N]
cadena nombre
cargar(pacientes)
ordenar_asc(pacientes)
Leer nombre
i = busqueda_bin(pacientes, nombre)
Si(i != -1)
entonces
	Escribir "El paciente",pacientes[i].nombre,"tiene DNI",pacientes[i].dni
sino Escribir "No se encontró el paciente con nombre", nombre
Escribir "El promedio de edad de los pacientes es de",prom(pacientes)
fin

